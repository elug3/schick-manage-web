{
  "family": "schick-manage-web-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::845061289093:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "manage-web-container",
      "image": "845061289093.dkr.ecr.us-east-1.amazonaws.com/manage-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "80"
        },
        {
          "name": "SCHICK_GATEWAY_URL",
          "value": "http://proxy.schick.local"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/schick-manage-web-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
